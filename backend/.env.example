# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=trendsight

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# LLM
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# Algo
ALGO_BASE_URL=http://127.0.0.1:8001
ALGO_SENTIMENT_METHOD=bert

# Crawler database (public_opinion_system)
# The analysis worker reads raw_documents/raw_comments from this database.
# Defaults match the web_crawler module out-of-box settings.
CRAWLER_DB_HOST=localhost
CRAWLER_DB_PORT=3306
CRAWLER_DB_USER=root
CRAWLER_DB_PASSWORD=
CRAWLER_DB_NAME=public_opinion_system


# Analysis worker
ANALYSIS_INTERVAL_MINUTES=30
