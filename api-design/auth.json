{
  "module": "auth",
  "description": "用户认证与个人中心相关接口，包括用户登录、用户信息查询以及关注配置管理。",
  "apis": [
    {
      "name": "用户登录",
      "method": "POST",
      "path": "/api/auth/login",
      "description": "用户通过用户名和密码登录系统，验证成功后返回身份认证Token。",
      "request": {
        "body": {
          "username": {
            "type": "string",
            "required": true,
            "description": "用户登录账号"
          },
          "password": {
            "type": "string",
            "required": true,
            "description": "用户登录密码"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "user_id": {
            "type": "integer",
            "description": "用户唯一ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "token": {
            "type": "string",
            "description": "JWT身份认证Token，用于后续接口身份验证"
          }
        }
      }
    },
    {
      "name": "获取用户信息",
      "method": "GET",
      "path": "/api/user/profile",
      "description": "获取当前登录用户的信息以及个人关注配置，用于个人中心展示。",
      "request": {
        "headers": {
          "Authorization": {
            "type": "string",
            "example": "Bearer jwt_xxx",
            "description": "用户身份认证请求头"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "user_id": {
            "type": "integer",
            "description": "用户唯一ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "preferences": {
            "type": "object",
            "description": "用户关注配置",
            "fields": {
              "fields": {
                "type": "array",
                "description": "用户关注领域列表",
                "example": [
                  "社会",
                  "科技",
                  "财经"
                ]
              },
              "keywords": {
                "type": "array",
                "description": "用户关注关键词列表",
                "example": [
                  "事故",
                  "疫情"
                ]
              },
              "platform_urls": {
                "type": "array",
                "description": "用户关注的新闻及社交平台网址列表",
                "items": {
                  "platform_name": {
                    "type": "string",
                    "description": "平台名称",
                    "example": "微博"
                  },
                  "url": {
                    "type": "string",
                    "description": "平台网址",
                    "example": "https://weibo.com"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "更新关注设置",
      "method": "PUT",
      "path": "/api/user/preferences",
      "description": "用户修改个人关注领域、关键词以及新闻社交平台网址配置。",
      "request": {
        "headers": {
          "Authorization": {
            "type": "string",
            "example": "Bearer jwt_xxx",
            "description": "用户身份认证请求头"
          }
        },
        "body": {
          "fields": {
            "type": "array",
            "required": true,
            "description": "用户关注领域列表",
            "example": [
              "社会",
              "科技"
            ]
          },
          "keywords": {
            "type": "array",
            "required": true,
            "description": "用户关注关键词列表",
            "example": [
              "事故",
              "经济"
            ]
          },
          "platform_urls": {
            "type": "array",
            "required": true,
            "description": "用户关注新闻和社交平台网址",
            "example": [
              {
                "platform_name": "微博",
                "url": "https://weibo.com"
              },
              {
                "platform_name": "知乎",
                "url": "https://zhihu.com"
              }
            ]
          }
        }
      },
      "response": {
        "code": 200,
        "message": "updated successfully",
        "data": {
          "fields": {
            "type": "array",
            "description": "更新后的关注领域"
          },
          "keywords": {
            "type": "array",
            "description": "更新后的关注关键词"
          },
          "platform_urls": {
            "type": "array",
            "description": "更新后的关注平台网址"
          }
        }
      }
    }
  ]
}