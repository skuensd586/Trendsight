{
  "module": "events",
  "description": "舆情事件展示与分析相关接口，包括热点事件列表、事件详情分析报告以及趋势、情感、平台、关键词等分析数据。",
  "apis": [
    {
      "name": "用户登录",
      "method": "POST",
      "path": "/api/auth/login",
      "description": "用户通过用户名和密码登录系统，验证成功后返回身份认证Token。",
      "request": {
        "body": {
          "username": {
            "type": "string",
            "required": true,
            "description": "用户登录账号"
          },
          "password": {
            "type": "string",
            "required": true,
            "description": "用户登录密码"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "user_id": {
            "type": "integer",
            "description": "用户唯一ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "token": {
            "type": "string",
            "description": "JWT身份认证Token"
          }
        }
      }
    },
    {
      "name": "获取用户信息",
      "method": "GET",
      "path": "/api/user/profile",
      "description": "获取当前登录用户的信息以及个人关注配置。",
      "request": {
        "headers": {
          "Authorization": {
            "type": "string",
            "example": "Bearer jwt_xxx",
            "description": "用户身份认证请求头"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "user_id": {
            "type": "integer",
            "description": "用户唯一ID"
          },
          "username": {
            "type": "string",
            "description": "用户名"
          },
          "preferences": {
            "type": "object",
            "description": "用户关注配置",
            "fields": {
              "fields": {
                "type": "array",
                "description": "关注领域列表",
                "example": [
                  "社会",
                  "科技"
                ]
              },
              "keywords": {
                "type": "array",
                "description": "关注关键词列表",
                "example": [
                  "事故",
                  "疫情"
                ]
              },
              "platform_urls": {
                "type": "array",
                "description": "关注平台网址列表",
                "items": {
                  "platform_name": {
                    "type": "string",
                    "description": "平台名称"
                  },
                  "url": {
                    "type": "string",
                    "description": "平台网址"
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "name": "更新关注设置",
      "method": "PUT",
      "path": "/api/user/preferences",
      "description": "用户修改个人关注领域、关键词以及新闻社交平台网址配置。",
      "request": {
        "headers": {
          "Authorization": {
            "type": "string",
            "example": "Bearer jwt_xxx"
          }
        },
        "body": {
          "fields": {
            "type": "array",
            "required": true,
            "description": "关注领域列表"
          },
          "keywords": {
            "type": "array",
            "required": true,
            "description": "关注关键词列表"
          },
          "platform_urls": {
            "type": "array",
            "required": true,
            "description": "关注平台网址列表"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "updated successfully",
        "data": {
          "fields": {
            "type": "array",
            "description": "更新后的关注领域"
          },
          "keywords": {
            "type": "array",
            "description": "更新后的关注关键词"
          },
          "platform_urls": {
            "type": "array",
            "description": "更新后的关注平台网址"
          }
        }
      }
    },
    {
      "name": "趋势数据",
      "method": "GET",
      "path": "/api/events/{event_id}/trend",
      "description": "获取指定事件的舆情传播趋势数据。",
      "request": {
        "path": {
          "event_id": {
            "type": "integer",
            "required": true,
            "description": "事件唯一ID"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "trend": [
            {
              "date": {
                "type": "string",
                "description": "日期"
              },
              "count": {
                "type": "integer",
                "description": "报道数量"
              }
            }
          ]
        }
      },
      "data_source": {
        "A": [
          "news_publish_time",
          "article_count"
        ],
        "B": [
          "trend_analysis"
        ]
      }
    },
    {
      "name": "情感分布",
      "method": "GET",
      "path": "/api/events/{event_id}/sentiment",
      "description": "获取指定事件的公众情感倾向分析结果。",
      "request": {
        "path": {
          "event_id": {
            "type": "integer",
            "required": true,
            "description": "事件唯一ID"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "positive": {
            "type": "float",
            "description": "正面情感比例"
          },
          "neutral": {
            "type": "float",
            "description": "中性情感比例"
          },
          "negative": {
            "type": "float",
            "description": "负面情感比例"
          }
        }
      },
      "data_source": {
        "B": [
          "sentiment_analysis_result"
        ]
      }
    },
    {
      "name": "平台分布",
      "method": "GET",
      "path": "/api/events/{event_id}/platform",
      "description": "统计不同新闻网站和社交平台对事件的报道占比。",
      "request": {
        "path": {
          "event_id": {
            "type": "integer",
            "required": true,
            "description": "事件唯一ID"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "platform_distribution": [
            {
              "platform_name": {
                "type": "string",
                "description": "平台名称"
              },
              "ratio": {
                "type": "float",
                "description": "报道占比"
              }
            }
          ]
        }
      },
      "data_source": {
        "A": [
          "source_platform"
        ],
        "C": [
          "statistics_calculation"
        ]
      }
    },
    {
      "name": "关键词分析",
      "method": "GET",
      "path": "/api/events/{event_id}/keywords",
      "description": "获取事件高频关键词及权重，用于生成词云。",
      "request": {
        "path": {
          "event_id": {
            "type": "integer",
            "required": true,
            "description": "事件唯一ID"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "keywords": [
            {
              "word": {
                "type": "string",
                "description": "关键词"
              },
              "weight": {
                "type": "float",
                "description": "权重"
              }
            }
          ]
        }
      },
      "data_source": {
        "B": [
          "word_frequency_analysis",
          "keyword_extraction"
        ]
      }
    },
    {
      "name": "热点事件列表",
      "method": "GET",
      "path": "/api/events/hot",
      "description": "获取首页舆情事件看板的热点事件列表，支持分页、排序和筛选。",
      "request": {
        "headers": {
          "Authorization": {
            "type": "string",
            "example": "Bearer jwt_xxx",
            "description": "用户身份认证Token"
          }
        },
        "query": {
          "q": {
            "type": "string",
            "required": false,
            "description": "搜索关键词，匹配标题/分类/地点/关键词"
          },
          "risk_level": {
            "type": "string",
            "required": false,
            "description": "风险筛选：all / high / mid_high / mid / low，默认 all"
          },
          "time_range": {
            "type": "string",
            "required": false,
            "description": "时间范围：today / 7d / 30d，默认 7d"
          },
          "sort": {
            "type": "string",
            "required": false,
            "description": "排序：heat / time / negative，默认 heat"
          },
          "page": {
            "type": "integer",
            "required": false,
            "description": "页码，默认1"
          },
          "page_size": {
            "type": "integer",
            "required": false,
            "description": "每页条数，默认20"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "pagination": {
            "page": {
              "type": "integer",
              "description": "当前页码"
            },
            "page_size": {
              "type": "integer",
              "description": "每页条数"
            },
            "total": {
              "type": "integer",
              "description": "总记录数"
            },
            "total_pages": {
              "type": "integer",
              "description": "总页数"
            }
          },
          "items": [
            {
              "event_id": {
                "type": "integer",
                "description": "事件唯一ID"
              },
              "title": {
                "type": "string",
                "description": "事件标题"
              },
              "category": {
                "type": "string",
                "description": "事件分类（来源待确认：需与算法模块确认）"
              },
              "event_time": {
                "type": "string",
                "description": "事件代表时间，格式 YYYY-MM-DD HH:mm:ss"
              },
              "location": {
                "type": "string",
                "description": "事件地点（来源待确认）"
              },
              "summary": {
                "type": "string",
                "description": "事件简要描述"
              },
              "heat": {
                "type": "float",
                "description": "热度指数"
              },
              "risk_level": {
                "type": "string",
                "description": "风险等级（来源待确认），枚举：high/mid_high/mid/low"
              },
              "stage": {
                "type": "string",
                "description": "生命周期阶段，枚举：latent/growth/peak/decline"
              },
              "report_count": {
                "type": "integer",
                "description": "去重后有效报道数"
              },
              "sentiment": {
                "type": "object",
                "description": "情感比例",
                "fields": {
                  "positive": {
                    "type": "float",
                    "description": "正面比例"
                  },
                  "neutral": {
                    "type": "float",
                    "description": "中性比例"
                  },
                  "negative": {
                    "type": "float",
                    "description": "负面比例"
                  }
                }
              },
              "keywords": {
                "type": "array",
                "description": "关键词列表，用于搜索匹配和标签展示"
              }
            }
          ]
        }
      },
      "data_source": {
        "A": [
          "title",
          "publish_time",
          "source_platform"
        ],
        "B": [
          "heat",
          "sentiment",
          "keywords",
          "stage",
          "report_count"
        ],
        "C": [
          "database_query",
          "pagination",
          "sorting"
        ]
      }
    },
    {
      "name": "事件详情",
      "method": "GET",
      "path": "/api/events/{event_id}",
      "description": "获取指定事件的详细分析报告主体数据。",
      "request": {
        "headers": {
          "Authorization": {
            "type": "string",
            "example": "Bearer jwt_xxx"
          }
        },
        "path": {
          "event_id": {
            "type": "integer",
            "required": true,
            "description": "事件唯一ID"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "event_id": {
            "type": "integer",
            "description": "事件唯一ID"
          },
          "title": {
            "type": "string",
            "description": "事件标题"
          },
          "category": {
            "type": "string",
            "description": "事件分类（来源待确认：需与算法模块确认）"
          },
          "event_time": {
            "type": "string",
            "description": "事件发生或聚合时间"
          },
          "location": {
            "type": "string",
            "description": "事件地点（来源待确认）"
          },
          "summary": {
            "type": "string",
            "description": "事件概览"
          },
          "cause": {
            "type": "string",
            "description": "事件直接起因（来源待确认：后续可由大模型生成）"
          },
          "people": {
            "type": "array",
            "description": "涉事主体列表，由算法事件详情抽取模块提取"
          },
          "heat": {
            "type": "float",
            "description": "热度指数"
          },
          "report_count": {
            "type": "integer",
            "description": "去重后有效报道数"
          },
          "time_start": {
            "type": "string",
            "description": "最早报道时间"
          },
          "time_end": {
            "type": "string",
            "description": "最晚报道时间"
          },
          "risk_level": {
            "type": "string",
            "description": "风险等级（来源待确认），枚举：high/mid_high/mid/low"
          },
          "stage": {
            "type": "string",
            "description": "生命周期阶段，枚举：latent/growth/peak/decline"
          },
          "sentiment": {
            "type": "object",
            "description": "情感比例",
            "fields": {
              "positive": {
                "type": "float",
                "description": "正面比例"
              },
              "neutral": {
                "type": "float",
                "description": "中性比例"
              },
              "negative": {
                "type": "float",
                "description": "负面比例"
              }
            }
          },
          "keywords": {
            "type": "array",
            "description": "高频关键词，每题项含 word 和 weight",
            "items": {
              "word": {
                "type": "string",
                "description": "关键词"
              },
              "weight": {
                "type": "float",
                "description": "权重"
              }
            }
          },
          "platform_distribution": {
            "type": "array",
            "description": "平台分布",
            "items": {
              "platform_name": {
                "type": "string",
                "description": "平台名称"
              },
              "ratio": {
                "type": "float",
                "description": "占比"
              }
            }
          },
          "lifecycle": {
            "type": "object",
            "description": "生命周期预测（格式与 lifecycle 接口一致）",
            "fields": {
              "stage": {
                "type": "string",
                "description": "阶段"
              },
              "confidence": {
                "type": "float",
                "description": "置信度"
              },
              "stage_probability": {
                "type": "object",
                "description": "各阶段概率",
                "fields": {
                  "latent": {
                    "type": "float"
                  },
                  "growth": {
                    "type": "float"
                  },
                  "peak": {
                    "type": "float"
                  },
                  "decline": {
                    "type": "float"
                  }
                }
              },
              "future_trend": {
                "type": "array",
                "description": "未来趋势预测"
              },
              "analysis": {
                "type": "string",
                "description": "阶段说明"
              }
            }
          },
          "advice": {
            "type": "string",
            "description": "处置建议（来源待确认：后续由大模型或规则引擎生成）"
          },
          "qa_seed": {
            "type": "string",
            "description": "问答兜底上下文（来源待确认）"
          },
          "authenticity": {
            "type": "object",
            "description": "真实性分析（来源待确认：后续由算法模块补充）",
            "fields": {
              "false_confidence": {
                "type": "float",
                "description": "真实性置信度"
              },
              "duplicate_rate": {
                "type": "float",
                "description": "重复率"
              },
              "credibility_factors": {
                "type": "array",
                "description": "真实性因子"
              },
              "checks": {
                "type": "array",
                "description": "真实性检查"
              }
            }
          },
          "propagation": {
            "type": "object",
            "description": "传播分析结果，由算法关键传播节点检测模块输出",
            "fields": {
              "key_nodes": {
                "type": "array",
                "description": "按时间排序的关键传播节点，例如初始爆料、首次大V发声、首次官方媒体介入、传播高峰"
              },
              "top_influencers": {
                "type": "array",
                "description": "按互动影响力排序的高影响账号"
              },
              "platform_chain": {
                "type": "object",
                "description": "平台首次出现顺序形成的平台级传播路径，含 nodes 与 links"
              }
            }
          },
          "traceability": {
            "type": "object",
            "description": "事件溯源图（来源待确认：后续由算法模块补充）",
            "fields": {
              "nodes": {
                "type": "array",
                "description": "溯源节点"
              },
              "links": {
                "type": "array",
                "description": "溯源连接"
              }
            }
          },
          "geo_discussion": {
            "type": "array",
            "description": "地域讨论热力（来源待确认：后续由算法模块补充）"
          },
          "similar_events": {
            "type": "array",
            "description": "历史相似事件（来源待确认：后续由算法模块补充）"
          }
        }
      },
      "data_source": {
        "A": [
          "title",
          "publish_time",
          "source_platform"
        ],
        "B": [
          "heat",
          "sentiment",
          "keywords",
          "stage",
          "platform_distribution"
        ],
        "C": [
          "database_query",
          "data_integration"
        ]
      }
    },
    {
      "name": "分析事件",
      "method": "POST",
      "path": "/api/events/analyze",
      "description": "接收原始文档列表，调用算法分析服务（B模块）进行NLP处理（聚类、情感、关键词、生命周期预测等），并将分析结果持久化到数据库。",
      "request": {
        "body": {
          "documents": {
            "type": "array",
            "required": true,
            "description": "原始新闻文档列表，每题项包含 doc_id/title/content/publish_time/source/platform/url"
          },
          "comments": {
            "type": "array",
            "required": false,
            "description": "评论列表（可选）"
          },
          "sentiment_method": {
            "type": "string",
            "required": false,
            "description": "情感分析方法，默认 bert"
          }
        }
      },
      "response": {
        "code": 200,
        "message": "success",
        "data": {
          "count": {
            "type": "integer",
            "description": "创建的事件数量"
          },
          "event_ids": {
            "type": "array",
            "description": "创建的事件ID列表",
            "items": {
              "type": "integer"
            }
          }
        }
      },
      "data_source": {
        "A": [
          "documents"
        ],
        "B": [
          "algo_analysis_result"
        ],
        "C": [
          "database_persistence"
        ]
      }
    }
  ]
}
