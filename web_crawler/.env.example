# 舆情分析系统 — 数据库配置模板
# 复制本文件为 .env，填入实际值
# .env 已被 .gitignore 排除，不会提交到仓库

DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=public_opinion_system

# 新浪新闻 Cookie
SINA_COOKIE=your_sina_cookie_here

# 微博 Cookie（登录后从浏览器开发者工具 → Application → Cookies → weibo.com 获取）
WEIBO_COOKIE=your_weibo_cookie_here

# 多账号支持（可选）：添加 WEIBO_COOKIE_2 / _3 / ... 实现账号轮换
# 当主 cookie 被限流或过期时，爬虫会自动切换到下一个可用账号
# WEIBO_COOKIE_2=your_second_weibo_cookie_here
# WEIBO_COOKIE_3=your_third_weibo_cookie_here
