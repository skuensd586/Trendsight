# 舆情分析系统 — 数据库配置模板
# 复制本文件为 .env，填入实际值
# .env 已被 .gitignore 排除，不会提交到仓库

DB_USER=root
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=public_opinion_system

# 新浪新闻 Cookie
SINA_COOKIE=your_sina_cookie_here
# 知乎 Cookie(zhihu.com)
ZHIHU_COOKIE=your_zhihu_cookie_here
# 微博 Cookie(m.weibo.cn)
WEIBO_COOKIE=your_weibo_cookie_here

# 多账号支持（可选）：添加 SINA_COOKIE_2 / _3 / ... 或 WEIBO_COOKIE_2 / _3 / ... 或 ZHIHU_COOKIE_2 / _3 / ... 实现账号轮换

